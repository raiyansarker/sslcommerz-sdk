{
    "name": "raiyansarker/sslcommerz-sdk",
    "description": "A modern, typesafe PHP SDK for SSLCommerz Payment Gateway using Saloon PHP.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Raiyan Sarker",
            "email": "developerraiyan@gmail.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "saloonphp/saloon": "^4.0",
        "guzzlehttp/guzzle": "^7.8"
    },
    "require-dev": {
        "orchestra/testbench": "^11.0",
        "pestphp/pest": "^4.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "RaiyanSarker\\SSLCommerz\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "RaiyanSarker\\SSLCommerz\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "stan": "vendor/bin/phpstan analyse --memory-limit=256M",
        "all": [
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "RaiyanSarker\\SSLCommerz\\Laravel\\SSLCommerzServiceProvider"
            ],
            "aliases": {
                "SSLCommerz": "RaiyanSarker\\SSLCommerz\\Laravel\\Facades\\SSLCommerz"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
