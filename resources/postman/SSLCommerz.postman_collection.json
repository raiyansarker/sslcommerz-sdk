                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "// Parse response and save session key",
                  "var jsonData = pm.response.json();",
                  "console.log('Full Response:', JSON.stringify(jsonData, null, 2));",
                  "",
                  "if (jsonData.status === 'SUCCESS') {",
                  "    pm.globals.set('sessionkey', jsonData.sessionkey);",
                  "    pm.globals.set('gateway_page_url', jsonData.GatewayPageURL);",
                  "    console.log('Session Key:', jsonData.sessionkey);",
                  "    console.log('Gateway URL:', jsonData.GatewayPageURL);",
                  "} else {",
                  "    console.log('Error Status:', jsonData.status);",
                  "    console.log('Error Message:', jsonData.failedreason);",
                  "}",
                  "",
                  "pm.test('Payment session created successfully', function () {",
                  "    pm.expect(jsonData.status).to.eql('SUCCESS');",
                  "});"
