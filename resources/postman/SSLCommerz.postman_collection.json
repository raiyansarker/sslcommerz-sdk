          "name": "Debug - Test Store Credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Debug response",
                  "console.log('Response Status:', pm.response.code);",
                  "",
                  "// Check if response is HTML (error page) or JSON",
                  "var contentType = pm.response.headers.get('content-type');",
                  "console.log('Content-Type:', contentType);",
                  "",
                  "if (contentType && contentType.includes('application/json')) {",
                  "    var jsonData = pm.response.json();",
                  "    console.log('JSON Response:', JSON.stringify(jsonData, null, 2));",
                  "    ",
                  "    // Test results",
                  "    pm.test('Status code is 200', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "    ",
                  "    if (jsonData.status === 'SUCCESS') {",
                  "        pm.test('✅ SSLCommerz connection successful', function () {",
                  "            pm.expect(jsonData.status).to.eql('SUCCESS');",
                  "        });",
                  "        console.log('✅ SUCCESS: SSLCommerz is working properly!');",
                  "        console.log('Session Key:', jsonData.sessionkey);",
                  "        console.log('Gateway URL:', jsonData.GatewayPageURL);",
                  "    } else {",
                  "        pm.test('❌ SSLCommerz connection failed', function () {",
                  "            pm.expect(jsonData.status).to.eql('SUCCESS');",
                  "        });",
                  "        console.log('❌ FAILED: ' + jsonData.failedreason);",
                  "    }",
                  "} else {",
                  "    console.log('❌ Non-JSON Response (likely HTML error page)');",
                  "    console.log('Response Body:', pm.response.text());",
                  "}"
                ]
              }
            }
